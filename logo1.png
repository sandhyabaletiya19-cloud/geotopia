<!-- DharaVerse Logo - Cosmic Earth -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <defs>
    <!-- Universe gradient -->
    <radialGradient id="universe" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#0a0a2e"/>
      <stop offset="100%" style="stop-color:#1a0533"/>
    </radialGradient>
    
    <!-- Earth gradient -->
    <radialGradient id="earth" cx="40%" cy="35%" r="50%">
      <stop offset="0%" style="stop-color:#4fc3f7"/>
      <stop offset="30%" style="stop-color:#4A90D9"/>
      <stop offset="60%" style="stop-color:#2D9B4E"/>
      <stop offset="100%" style="stop-color:#1a5c2e"/>
    </radialGradient>
    
    <!-- Glow effect -->
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:0.6"/>
      <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:0"/>
    </radialGradient>
    
    <!-- Atmosphere -->
    <radialGradient id="atmosphere" cx="50%" cy="50%" r="50%">
      <stop offset="70%" style="stop-color:transparent"/>
      <stop offset="85%" style="stop-color:rgba(74,144,217,0.3)"/>
      <stop offset="100%" style="stop-color:rgba(74,144,217,0.1)"/>
    </radialGradient>

    <!-- Galaxy ring gradient -->
    <linearGradient id="ring" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:0.1"/>
      <stop offset="25%" style="stop-color:#EC4899;stop-opacity:0.8"/>
      <stop offset="50%" style="stop-color:#8B5CF6;stop-opacity:1"/>
      <stop offset="75%" style="stop-color:#06B6D4;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:0.1"/>
    </linearGradient>
  </defs>
  
  <!-- Outer glow -->
  <circle cx="100" cy="100" r="95" fill="url(#glow)"/>
  
  <!-- Stars -->
  <circle cx="30" cy="25" r="1.5" fill="white" opacity="0.8"/>
  <circle cx="170" cy="30" r="1" fill="white" opacity="0.6"/>
  <circle cx="15" cy="80" r="1" fill="white" opacity="0.7"/>
  <circle cx="185" cy="85" r="1.5" fill="white" opacity="0.5"/>
  <circle cx="25" cy="140" r="1" fill="white" opacity="0.9"/>
  <circle cx="175" cy="150" r="1" fill="white" opacity="0.6"/>
  <circle cx="50" cy="175" r="1.5" fill="white" opacity="0.7"/>
  <circle cx="150" cy="170" r="1" fill="white" opacity="0.8"/>
  <circle cx="85" cy="15" r="1" fill="white" opacity="0.6"/>
  <circle cx="120" cy="185" r="1" fill="white" opacity="0.5"/>
  <circle cx="45" cy="50" r="0.8" fill="white" opacity="0.4"/>
  <circle cx="155" cy="55" r="0.8" fill="white" opacity="0.5"/>
  <circle cx="40" cy="160" r="0.8" fill="white" opacity="0.6"/>
  <circle cx="160" cy="165" r="0.8" fill="white" opacity="0.4"/>
  
  <!-- Galaxy orbit ring (behind earth) -->
  <ellipse cx="100" cy="100" rx="85" ry="30" 
           fill="none" stroke="url(#ring)" stroke-width="2"
           transform="rotate(-20, 100, 100)" opacity="0.6"/>
  
  <!-- Earth globe -->
  <circle cx="100" cy="100" r="55" fill="url(#earth)"/>
  
  <!-- Continent shapes (simplified) -->
  <!-- Americas -->
  <path d="M75,70 Q78,65 82,68 L85,75 Q83,82 80,88 L76,95 Q73,100 75,105 L78,112 Q76,118 72,115 L70,108 Q68,100 70,92 L72,85 Q73,78 75,70Z" 
        fill="#2D9B4E" opacity="0.7"/>
  
  <!-- Africa/Europe -->
  <path d="M108,65 Q112,62 115,65 L118,72 Q120,78 118,85 L115,95 Q113,102 115,108 L112,115 Q108,112 110,105 L108,95 Q106,85 108,75Z" 
        fill="#2D9B4E" opacity="0.7"/>
  
  <!-- Asia -->
  <path d="M120,60 Q128,55 135,60 L138,68 Q140,75 137,80 L132,85 Q128,82 125,78 L122,72 Q120,66 120,60Z" 
        fill="#2D9B4E" opacity="0.6"/>
  
  <!-- Atmosphere shine -->
  <circle cx="100" cy="100" r="55" fill="url(#atmosphere)"/>
  
  <!-- Light reflection -->
  <ellipse cx="82" cy="80" rx="20" ry="25" 
           fill="white" opacity="0.08"
           transform="rotate(-30, 82, 80)"/>
  
  <!-- Galaxy orbit ring (in front of earth) -->
  <path d="M15,100 Q100,70 185,100" 
        fill="none" stroke="url(#ring)" stroke-width="2"
        transform="rotate(-20, 100, 100)" opacity="0.4"/>
  
  <!-- Sanskrit धरा watermark on globe -->
  <text x="92" y="108" font-family="serif" font-size="18" 
        fill="white" opacity="0.15" font-weight="bold">धरा</text>
  
  <!-- Small orbiting dot (like satellite) -->
  <circle cx="160" cy="65" r="3" fill="#EC4899" opacity="0.8">
    <animateTransform attributeName="transform" type="rotate"
      from="0 100 100" to="360 100 100" dur="20s" repeatCount="indefinite"/>
  </circle>
</svg>
